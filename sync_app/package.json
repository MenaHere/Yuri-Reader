{
  "name": "yuri-sync",
  "version": "0.1.0",
  "description": "Yuri-Sync — MALSync-based tracking service for Yuri-Reader",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/server.ts",
    "start": "node dist/server.js",
    "build:binary": "pkg dist/server.js --targets node20-linux-x64,node20-win-x64,node20-macos-x64 --output dist/yuri-sync"
  },
  "keywords": [
    "manga",
    "anime",
    "tracker",
    "mal",
    "anilist"
  ],
  "author": "",
  "license": "GPL-3.0",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
